# SO-101 policy evaluation defaults (MolmoAct2 or Pi).
#
# Copy any line into `.env.local` (same directory) to override without editing
# this file. `.env.local` is optional and not tracked by git.
#
# Format: KEY=value, one per line; `#` comments and blank lines are ignored.

# Policy backend:
#   molmoact2 - allenai/MolmoAct2-SO100_101 (default)
#   pi        - open-source LeRobot pi05/pi0 (Pi 0.7 weights are not public yet)
EVAL_POLICY=molmoact2

# Inference mode:
#   local  - auto-start the policy server on this machine
#   remote - use an existing HTTP /act endpoint
EVAL_INFERENCE=local

# --- MolmoAct2 settings (EVAL_POLICY=molmoact2) ---

# Path to the molmoact2 repo (local mode only).
MOLMOACT2_HOME=~/workspace/molmoact2

# Managed local MolmoAct2 server bind settings.
MOLMOACT_LOCAL_HOST=127.0.0.1
MOLMOACT_LOCAL_PORT=8101
MOLMOACT_LOCAL_STARTUP_TIMEOUT_S=600

# Remote MolmoAct2 FastAPI /act endpoint (remote mode).
MOLMOACT_ENDPOINT=http://192.168.0.233:8014/act

# --- Pi settings (EVAL_POLICY=pi) ---
# Pi 0.7 is not publicly released. Use pi05 (recommended) or pi0 checkpoints.
# On AMD Strix Halo, run setup_amd_pi.sh once so local inference uses ROCm.

PI_CHECKPOINT=lerobot/pi05_base
PI_POLICY_TYPE=pi05
PI_DEVICE=auto
# Strix Halo defaults: bfloat16 + 5 denoise steps (policy default is float32/10 and is much slower).
PI_DTYPE=bfloat16
PI_NUM_INFERENCE_STEPS=5
PI_ROBOT_TYPE=
PI_MAX_ACTIONS=
PI_TOP_IMAGE_KEY=
PI_SIDE_IMAGE_KEY=
# Optional: local path if you already downloaded the gated PaliGemma tokenizer.
# PI_TOKENIZER_NAME=
# Optional override: path to a ROCm-enabled Python (defaults to .venv-rocm/bin/python).
# PI_PYTHON=

PI_LOCAL_HOST=127.0.0.1
PI_LOCAL_PORT=8102
PI_LOCAL_STARTUP_TIMEOUT_S=900

# Remote Pi /act endpoint (remote mode). Lab GPU host jedld-lab serves Pi on port 8102.
PI_ENDPOINT=http://jedld-lab:8102/act

# --- Shared UI / robot settings ---

# LeRobot calibration id for the SO-101 follower (from lerobot-calibrate --robot.id=...).
EVAL_ROBOT_ID=my_awesome_follower_arm

# Local browser UI bind address and port.
EVAL_UI_HOST=127.0.0.1
EVAL_UI_PORT=7860

# Server log level: DEBUG, INFO, WARNING, or ERROR.
EVAL_LOG_LEVEL=INFO

# Legacy aliases (still read if the EVAL_* keys above are unset).
MOLMOACT_INFERENCE=local
MOLMOACT_ROBOT_ID=my_awesome_follower_arm
MOLMOACT_UI_HOST=127.0.0.1
MOLMOACT_UI_PORT=7860
MOLMOACT_LOG_LEVEL=INFO
